{
    "firestore": {
        "rules": "firestore.rules",
        "indexes": "firestore.indexes.json"
    },
    "hosting": {
        "site": "navafundacionorg",
        "public": "out",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "cleanUrls": true,
        "rewrites": [
            {
                "source": "/catalog/**",
                "destination": "/catalog/1.html"
            },
            {
                "source": "/projects/**",
                "destination": "/projects/1.html"
            },
            {
                "source": "/blog/**",
                "destination": "/blog/1.html"
            }
        ]
    }
}